DATABASE_URL=postgresql://user:password@localhost:5432/trafficforge
PORT=8080
NODE_ENV=development
BASE_PATH=/
LOG_LEVEL=info

# ─── LLM provider configuration ──────────────────────────────────────────────
# Default: ollama (local, free, no API key needed).
# Override with LLM_PROVIDER to use a different primary; LLM_FALLBACK lists
# additional providers tried in order if the primary is unavailable.
#
# Supported: anthropic | groq | cerebras | ollama | openrouter | deepseek | none
# Switch providers by changing ONE line: LLM_PROVIDER=groq  or  LLM_PROVIDER=anthropic
LLM_PROVIDER=groq
LLM_FALLBACK=groq,anthropic,ollama

# ─── Provider credentials (set the ones you use) ─────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Groq Cloud — free tier at https://console.groq.com (Llama 3.3 70B)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras — free tier at https://cloud.cerebras.ai (very fast Llama)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# OpenRouter — free models at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# DeepSeek — paid but ~50x cheaper than Claude (deepseek-chat / deepseek-reasoner)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Ollama — local server. Default host: http://localhost:11434. Pull with `ollama pull llama3.1:8b`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
